# Environment for Docker Compose


# Redis
REDIS_PORT=6380
REDIS_INTERNAL_PORT=6380
REDIS_HOST=Redis
LOG_LEVEL=INFO

# BE
BE_BASE_PORT=7000
BE_INTERNAL_PORT=7000

# Host folder mounted into the backend container (single mount default)
PCAP_DIRECTORIES=./pcaps
# Container path where PCAP_DIRECTORIES is mounted
PCAP_MOUNTED_DIRECTORY=/pcaps
# Optional: comma-separated container roots when using multiple volume mounts
# PCAP_ROOT_DIRECTORIES=/pcaps/archive,/pcaps/lab
# Optional: comma-separated host display paths (aligned with roots above)
# PCAP_PREFIX_STR=./archive,./lab

BE_BASE_URL=localhost

# FE
FRONTEND_PORT=5000
NGINX_PORT=80
